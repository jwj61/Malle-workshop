G:=TransitiveGroup(6,9);
T:=DerivedSubgroup(G);
A:=quo<G|Fix(T)>;


function PD_H1ur_Bound2(G,M)
    dM:=NumberOfGenerators(M);
    Z:=Fix(T);
    ZGT:=quo<G|Z>;
    function weight(C)
        return dM/2*#ZGT*(1-C`order^(-1));
    end function;
    return weight;
end function;

SCs:=CyclicSubgroups(A);
PD_H1ur_Bound2(G,T)(SCs[2]);
