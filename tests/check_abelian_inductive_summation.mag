load "utils/Abelian_Inductive_Summation.mag";

eps:=10^-8;

assert_real_equal:=procedure(actual, expected)
    assert Abs(actual - expected) lt eps;
end procedure;

value_for_generator_order:=function(F,cyclic_generators,order)
    vals:=[F(g) : g in cyclic_generators | Order(g) eq order];
    error if #vals ne 1, "Expected a unique cyclic subgroup class of this order";
    return vals[1];
end function;

/*
Inertial_Multiplicity_Bound tests.
*/
B:=CyclicGroup(6);
cyclic_generators:=CyclicSubgroupGeneratorRepresentatives(B);
F:=Inertial_Multiplicity_Bound(B);
assert_real_equal(value_for_generator_order(F,cyclic_generators,1), 0.0);
assert_real_equal(value_for_generator_order(F,cyclic_generators,2), 2.0*Sqrt(6));
assert_real_equal(value_for_generator_order(F,cyclic_generators,3), (8.0/3.0)*Sqrt(6));
assert_real_equal(value_for_generator_order(F,cyclic_generators,6), (10.0/3.0)*Sqrt(6));

B:=SymmetricGroup(3);
cyclic_generators:=CyclicSubgroupGeneratorRepresentatives(B);
F:=Inertial_Multiplicity_Bound(B);
assert #cyclic_generators eq 3;
assert_real_equal(value_for_generator_order(F,cyclic_generators,1), 0.0);
assert_real_equal(value_for_generator_order(F,cyclic_generators,2), 2.0*Sqrt(6));
assert_real_equal(value_for_generator_order(F,cyclic_generators,3), (8.0/3.0)*Sqrt(6));
for b in cyclic_generators do
    assert Parent(b) eq B;
end for;

/*
Pushforward_Discriminant_Exponents tests.
*/
G:=SymmetricGroup(3);
T:=sub<G|Id(G)>;
Q,q,cyclic_generators:=QuotientCyclicSubgroupGeneratorRepresentatives(G,T);
F:=Pushforward_Discriminant_Exponents(G,T,q,cyclic_generators);
assert #cyclic_generators eq 3;
assert_real_equal(value_for_generator_order(F,cyclic_generators,1), 0.0);
assert_real_equal(value_for_generator_order(F,cyclic_generators,2), 1.0);
assert_real_equal(value_for_generator_order(F,cyclic_generators,3), 2.0);

/*
For S4 with T=V4, the quotient is S3.  In the natural degree-4 action of S4,
the identity coset has minimum index 0, an order-2 quotient coset has a
transposition lift of index 1, and an order-3 quotient coset has a 3-cycle
lift of index 2.
*/
G:=SymmetricGroup(4);
T:=sub<G|(1,2)(3,4),(1,3)(2,4)>;
Q,q,cyclic_generators:=QuotientCyclicSubgroupGeneratorRepresentatives(G,T);
F:=Pushforward_Discriminant_Exponents(G,T,q,cyclic_generators);
assert #cyclic_generators eq 3;
assert_real_equal(value_for_generator_order(F,cyclic_generators,1), 0.0);
assert_real_equal(value_for_generator_order(F,cyclic_generators,2), 1.0);
assert_real_equal(value_for_generator_order(F,cyclic_generators,3), 2.0);

wrong_parent_generators:=CyclicSubgroupGeneratorRepresentatives(G);
error_seen:=false;
try
    F:=Pushforward_Discriminant_Exponents(G,T,q,wrong_parent_generators);
catch e
    error_seen:=true;
end try;
assert error_seen;

/*
Inductive_Theta_Bound tests.
*/
G:=SymmetricGroup(3);
T:=sub<G|Id(G)>;
Q,q,cyclic_generators:=QuotientCyclicSubgroupGeneratorRepresentatives(G,T);
theta:=Inductive_Theta_Bound(G,T,q,cyclic_generators);
assert_real_equal(theta,2.0*Sqrt(6));

/*
For S4 with T=V4, the order-2 and order-3 quotient classes give
(2*sqrt(6)+3/2)/1 and ((8/3)*sqrt(6)+2)/2 respectively.  The former is
larger.
*/
G:=SymmetricGroup(4);
T:=sub<G|(1,2)(3,4),(1,3)(2,4)>;
Q,q,cyclic_generators:=QuotientCyclicSubgroupGeneratorRepresentatives(G,T);
theta:=Inductive_Theta_Bound(G,T,q,cyclic_generators);
assert_real_equal(theta,2.0*Sqrt(6)+1.5);

missing_identity_generators:=[gT : gT in cyclic_generators | gT ne Id(Q)];
error_seen:=false;
try
    theta:=Inductive_Theta_Bound(G,T,q,missing_identity_generators);
catch e
    error_seen:=true;
end try;
assert error_seen;

/*
Generator-count tests for MinimalGModuleGenerators.
*/
G:=PermutationGroup<4 | (1,2), (3,4)>;
T:=G;
assert IsAbelian(T);
assert MinimalGModuleGenerators(G,T) eq 2;

G:=CyclicGroup(4);
T:=G;
assert MinimalGModuleGenerators(G,T) eq 1;

G:=SymmetricGroup(3);
T:=sub<G|(1,2,3)>;
assert MinimalGModuleGenerators(G,T) eq 1;

/*
In S4, the normal V4 is generated by one element as an S4-module under
conjugation, because the conjugates of any nontrivial element give all of V4.
*/
G:=SymmetricGroup(4);
T:=sub<G|(1,2)(3,4),(1,3)(2,4)>;
assert MinimalGModuleGenerators(G,T) eq 1;

G:=SymmetricGroup(3);
T:=sub<G|(1,2)>;
error_seen:=false;
try
    d:=MinimalGModuleGenerators(G,T);
catch e
    error_seen:=true;
end try;
assert error_seen;

/*
If G is abelian, then G/Centralizer_G(T) is trivial, so every value is zero.
*/
G:=CyclicGroup(4);
T:=sub<G|G.1^2>;
Q,q,cyclic_generators:=QuotientCyclicSubgroupGeneratorRepresentatives(G,T);
F:=PD_H1ur_Bound_Vec(G,T,q,cyclic_generators);
for g in cyclic_generators do
    assert Parent(g) eq Q;
    assert_real_equal(F(g), 0.0);
end for;

/*
For S3 with T=A3, Centralizer_G(T)=T and G/T maps isomorphically to B'=C2.
Since MinimalGModuleGenerators(G,T)=1, the nontrivial cyclic subgroup
contributes (1/2)*2*(1-1/2)=1/2.
*/
G:=SymmetricGroup(3);
T:=sub<G|(1,2,3)>;
Q,q,cyclic_generators:=QuotientCyclicSubgroupGeneratorRepresentatives(G,T);
F:=PD_H1ur_Bound_Vec(G,T,q,cyclic_generators);
assert #cyclic_generators eq 2;
assert_real_equal(value_for_generator_order(F,cyclic_generators,1), 0.0);
assert_real_equal(value_for_generator_order(F,cyclic_generators,2), 0.5);

/*
For S4 with T=V4, Centralizer_G(T)=T and B'=G/T is S3.
Since MinimalGModuleGenerators(G,T)=1, the cyclic subgroup classes have
orders 1, 2, and 3, giving values 0, (1/2)*6*(1-1/2)=3/2,
and (1/2)*6*(1-1/3)=2.
*/
G:=SymmetricGroup(4);
T:=sub<G|(1,2)(3,4),(1,3)(2,4)>;
Q,q,cyclic_generators:=QuotientCyclicSubgroupGeneratorRepresentatives(G,T);
F:=PD_H1ur_Bound_Vec(G,T,q,cyclic_generators);
assert #cyclic_generators eq 3;
assert_real_equal(value_for_generator_order(F,cyclic_generators,1), 0.0);
assert_real_equal(value_for_generator_order(F,cyclic_generators,2), 1.5);
assert_real_equal(value_for_generator_order(F,cyclic_generators,3), 2.0);

/*
For C3^2 semidirect C2, with C2 acting by inversion, T=C3^2 has
MinimalGModuleGenerators(G,T)=2.  The factor 2/2 is therefore 1, so the
nontrivial class of G/T=C2 still contributes 2*(1-1/2)=1.
*/
G:=PermutationGroup<6 | (1,2,3), (4,5,6), (2,3)(5,6)>;
T:=sub<G|(1,2,3),(4,5,6)>;
Q,q,cyclic_generators:=QuotientCyclicSubgroupGeneratorRepresentatives(G,T);
F:=PD_H1ur_Bound_Vec(G,T,q,cyclic_generators);
assert #cyclic_generators eq 2;
assert MinimalGModuleGenerators(G,T) eq 2;
assert_real_equal(value_for_generator_order(F,cyclic_generators,1), 0.0);
assert_real_equal(value_for_generator_order(F,cyclic_generators,2), 1.0);

/*
PD_H1ur_Bound_Vec should reject generator lists whose elements do not live in
the codomain of the quotient map being used.
*/
G:=SymmetricGroup(3);
T:=sub<G|(1,2,3)>;
Q,q,cyclic_generators:=QuotientCyclicSubgroupGeneratorRepresentatives(G,T);
wrong_parent_generators:=CyclicSubgroupGeneratorRepresentatives(G);
error_seen:=false;
try
    F:=PD_H1ur_Bound_Vec(G,T,q,wrong_parent_generators);
catch e
    error_seen:=true;
end try;
assert error_seen;

/*
The function requires T to be normal, because G/T is used.
*/
G:=SymmetricGroup(3);
T:=sub<G|(1,2)>;
cyclic_generators:=CyclicSubgroupGeneratorRepresentatives(G);
error_seen:=false;
try
    F:=PD_H1ur_Bound_Vec(G,T,IdentityHomomorphism(G),cyclic_generators);
catch e
    error_seen:=true;
end try;
assert error_seen;

print "Abelian_Inductive_Summation tests passed";

quit;
